generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Incubator {
  id        String   @id @default(uuid())
  name      String   @default("Incubator 1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sensorLogs         SensorLog[]
  incubationSessions IncubationSession[]
  settings           Setting[]

  @@map("incubators")
}

model SensorLog {
  id           String   @id @default(uuid())
  incubatorId  String
  temperature  Float
  humidity     Float
  heaterOn     Boolean
  fanOn        Boolean
  createdAt    DateTime @default(now())

  incubator Incubator @relation(fields: [incubatorId], references: [id], onDelete: Cascade)

  @@index([incubatorId, createdAt])
  @@map("sensor_logs")
}

model IncubationSession {
  id          String    @id @default(uuid())
  incubatorId String
  name        String?
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  isActive    Boolean   @default(true)

  incubator Incubator @relation(fields: [incubatorId], references: [id], onDelete: Cascade)

  @@index([incubatorId, isActive])
  @@map("incubation_sessions")
}

model Setting {
  id          String @id @default(uuid())
  incubatorId String
  key         String
  value       String

  incubator Incubator @relation(fields: [incubatorId], references: [id], onDelete: Cascade)

  @@unique([incubatorId, key])
  @@map("settings")
}
